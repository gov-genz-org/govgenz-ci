# Modèle pour production (sans secrets). Copier vers env.production.example localement
# ou laisser CI générer .env via deploy/generate-dotenv.sh (DEPLOY_GENERATE_ENV=true).
# Ne jamais committer de mots de passe / clés réelles.

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'https://www.example.org/'
app.forceGlobalSecureRequests = true

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = CHANGER_NOM_BDD
database.default.username = CHANGER_USER
database.default.password = CHANGER_MOT_DE_PASSE
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

encryption.key = hex2bin:REMPLACER_PAR_CLE_GENEREE

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

session.driver = CodeIgniter\Session\Handlers\FileHandler
session.expiration = 7200

#--------------------------------------------------------------------
# EMAIL
#--------------------------------------------------------------------

email.fromEmail = 'noreply@example.org'
email.fromName = 'Gov Gen Z'
join.notification.to = 'apps@example.org'
email.protocol = mail

staff.invite.expiryHours = 24

#--------------------------------------------------------------------
# ANALYTICS
#--------------------------------------------------------------------

analytics.enabled = true
analytics.ga4MeasurementId = CHANGER_GA4
analytics.privacyPageSlug = mentions-legales

#--------------------------------------------------------------------
# Hôtes / URLs
#--------------------------------------------------------------------

app.projectsUsePathPrefix = true
app.positionsUsePathPrefix = true

#--------------------------------------------------------------------
# ASSETS VERSION, FOR CACHEFRONT
#--------------------------------------------------------------------
app.assetVersion = 202605211202
