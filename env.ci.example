# Copier vers `.env` à la racine de govgenz-ci/ (non versionné).
# Docker : dossier ../govgenz-local/ — fragment optionnel ../govgenz-local/env.docker.fragment.example

CI_ENVIRONMENT = development

app.baseURL = 'http://localhost:8082/'
app.forceGlobalSecureRequests = false

database.default.hostname = db
database.default.database = govgenz
database.default.username = govgenz
database.default.password = govgenz
database.default.DBDriver = MySQLi
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci

# Générer une clé depuis govgenz-local/ : docker compose exec web php spark key:generate
encryption.key = base64:VOTRE_CLE_ICI

session.driver = CodeIgniter\Session\Handlers\FileHandler

# Envoi e-mail (formulaire Rejoindre → apps@govgenz.org par défaut)
# Sur mutualisé type WordPress : souvent PAS besoin de SMTP — protocol mail + PHP mail().
# Si email.fromEmail est vide : From automatique noreply@{domaine de app.baseURL} (sauf localhost).
# Définissez email.fromEmail pour forcer l’expéditeur (SPF/DMARC, domaine vérifié).
# email.fromEmail = 'noreply@votredomaine.org'
# email.fromName = 'Gov Gen Z site'
# email.protocol = mail
# join.notification.to = 'apps@govgenz.org'
#
# SMTP uniquement si votre hébergeur l’exige ou si mail() est désactivé :
# email.protocol = smtp
# email.SMTPHost = smtp.example.com
# email.SMTPUser = ...
# email.SMTPPass = ...
# email.SMTPPort = 587
# email.SMTPCrypto = tls
