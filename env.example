#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'CHANGE_URL'
app.forceGlobalSecureRequests = true

#--------------------------------------------------------------------
# DATABASE (Docker Compose — service db)
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = CHANGER_NOM_BDD
database.default.username = CHANGER_USER
database.default.password = CHANGER_MOT_DE_PASSE
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

encryption.key = hex2bin:REMPLACER_PAR_CLE_GENEREE

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

session.driver = CodeIgniter\Session\Handlers\FileHandler
session.expiration = 7200

#--------------------------------------------------------------------
# EMAIL
#--------------------------------------------------------------------

email.fromEmail = 'noreply@genzgov.org'
email.fromName = 'Gov Gen Z'
# Secours si aucun compte staff actif en BDD (staff_users). Sinon : e-mails des comptes actifs admin/éditeur (hors invitation en attente).
join.notification.to = 'apps@govgenz.org'
email.protocol = mail

# Lien d’invitation back-office (heures) — défaut 24 h
staff.invite.expiryHours = 24

#--------------------------------------------------------------------
# ANALYTICS (site public — Google Analytics 4 + bandeau cookies)
#--------------------------------------------------------------------

analytics.enabled = true
analytics.ga4MeasurementId = CHANGER_GA4
analytics.privacyPageSlug = mentions-legales


#--------------------------------------------------------------------
# Hôtes / URLs (différents entre staging et production — secrets GitHub par environment)
#--------------------------------------------------------------------

app.projectsUsePathPrefix = true
app.positionsUsePathPrefix = true

# Si sous-domaines dédiés (vhost séparé), renseigner host + baseURL pour CET environnement :
# app.projectsHost = projects.genzgov.org
# app.projectsBaseURL = 'https://projects.genzgov.org/'
# app.positionsHost = positions.genzgov.org
# app.positionsBaseURL = 'https://positions.genzgov.org/'

#--------------------------------------------------------------------
# ASSETS VERSION, FOR CACHEFRONT
#--------------------------------------------------------------------
app.assetVersion = 202605211202
