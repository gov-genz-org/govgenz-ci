#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8082/'
app.forceGlobalSecureRequests = false

#--------------------------------------------------------------------
# DATABASE (Docker Compose — service db)
#--------------------------------------------------------------------

database.default.hostname = db
database.default.database = govgenz
database.default.username = govgenz
database.default.password = govgenz
database.default.DBDriver = MySQLi
database.default.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

encryption.key = 

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

session.driver = CodeIgniter\Session\Handlers\FileHandler


#--------------------------------------------------------------------
# SUBDOMAIN BASE URL
#--------------------------------------------------------------------



# Sous-domaine « projects » (même appli, autre vhost / dossier B). Laisser vide = désactivé.
# HTTP_HOST n’envoie souvent pas le port : tu peux mettre projects.localhost:8082 OU projects.localhost
# (le code accepte projects.localhost si SERVER_PORT = le port du .env).

# true = URLs /projects/… sur le même domaine (développement module) ; false = placeholder /projects bloqué jusqu’au sous-domaine.
app.projectsUsePathPrefix = true
app.positionsUsePathPrefix = true
#app.projectsHost = projects.localhost:8082
#app.projectsBaseURL = 'http://projects.localhost:8082/'